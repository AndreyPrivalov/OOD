{
  "$schema": "https://biomejs.dev/schemas/1.9.4/schema.json",
  "formatter": {
    "enabled": true,
    "indentStyle": "space"
  },
  "linter": {
    "enabled": true
  },
  "files": {
    "ignoreUnknown": true,
    "ignore": [
      ".next/**",
      "dist/**",
      "coverage/**",
      ".turbo/**",
      ".vercel/**",
      "node_modules/**"
    ]
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "double",
      "semicolons": "asNeeded"
    }
  }
}
